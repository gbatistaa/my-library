@baseUrl = http://localhost:8080/library

### Get all books (Mock return)
GET {{baseUrl}}/book
Accept: application/json

### Create Book 1: The Fellowship of the Ring
POST {{baseUrl}}/book
Content-Type: application/json

{
  "name": "The Fellowship of the Ring",
  "author": "J.R.R. Tolkien",
  "rating": 5,
  "pages": 423,
  "isbn": "9780618640157",
  "genre": "Fantasy",
  "status": "COMPLETED"
}

